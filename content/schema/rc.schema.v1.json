{
  "$id": "rc.schema.v1",
  "title": "CAT OS Reading Comprehension content item, schema v1",
  "description": "Mechanical form of CONTENT_DATABASE_SCHEMA.md for RC items. Written against the validation subset implemented in src/core/content-loader/validator.js (type, required, properties, additionalProperties, items, minItems/maxItems, enum, const, minimum/maximum, minLength, pattern). Schema versions are appended, never replaced: a future v2 becomes rc.schema.v2.json and the loader handles both.",
  "type": "object",
  "required": ["schema_version", "meta", "passage", "questions", "vocabulary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },

    "meta": {
      "type": "object",
      "required": [
        "id", "type", "version", "status", "quality_score",
        "genre", "difficulty", "difficulty_numeric",
        "word_count", "question_count", "question_types",
        "theme", "estimated_time_min", "source",
        "date_added", "batch_id", "prompt_version",
        "reviewer_notes", "vocab_extracted"
      ],
      "additionalProperties": false,
      "properties": {
        "id":      { "type": "string", "pattern": "^rc-[0-9]{4}$" },
        "type":    { "const": "rc" },
        "version": { "type": "integer", "minimum": 1 },
        "status":  { "enum": ["draft", "review", "accepted", "rejected", "retired"] },
        "quality_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "genre": {
          "enum": [
            "philosophy", "economics", "political-theory", "history",
            "science", "sociology", "arts-culture", "literature-theory",
            "psychology", "anthropology", "technology-ethics", "environment"
          ]
        },
        "difficulty": { "enum": ["easy", "medium", "hard"] },
        "difficulty_numeric": { "type": "integer", "minimum": 1, "maximum": 10 },
        "word_count": { "type": "integer", "minimum": 400, "maximum": 700 },
        "question_count": { "type": "integer", "minimum": 3, "maximum": 5 },
        "question_types": {
          "type": "array",
          "minItems": 3,
          "items": {
            "enum": [
              "main_idea", "inference", "tone", "vocabulary_in_context",
              "logical_structure", "specific_detail", "title_selection",
              "paragraph_function", "author_purpose", "strengthen_weaken"
            ]
          }
        },
        "theme": { "type": "string", "minLength": 3 },
        "estimated_time_min": { "type": "number", "minimum": 1 },
        "source": {
          "type": "object",
          "required": ["publication", "url", "author", "date_accessed", "usage_note"],
          "additionalProperties": false,
          "properties": {
            "publication":   { "type": "string", "minLength": 1 },
            "url":           { "type": ["string", "null"] },
            "author":        { "type": ["string", "null"] },
            "date_accessed": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
            "usage_note":    { "type": "string", "minLength": 1 }
          }
        },
        "date_added": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "batch_id": { "type": "string", "pattern": "^batch-rc-[0-9]{3}$" },
        "prompt_version": { "type": "string", "minLength": 1 },
        "reviewer_notes": { "type": "string" },
        "vocab_extracted": { "type": "array", "items": { "type": "string" } }
      }
    },

    "passage": {
      "type": "object",
      "required": ["title", "paragraphs", "reading_time_min"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 3 },
        "paragraphs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "additionalProperties": false,
            "properties": {
              "id":   { "type": "string", "pattern": "^rc-[0-9]{4}-p[0-9]+$" },
              "text": { "type": "string", "minLength": 40 }
            }
          }
        },
        "reading_time_min": { "type": "number", "minimum": 1 }
      }
    },

    "questions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "type", "stem", "options", "correct", "estimated_time_sec", "explanation"],
        "additionalProperties": false,
        "properties": {
          "id":   { "type": "string", "pattern": "^rc-[0-9]{4}-q[0-9]+$" },
          "type": {
            "enum": [
              "main_idea", "inference", "tone", "vocabulary_in_context",
              "logical_structure", "specific_detail", "title_selection",
              "paragraph_function", "author_purpose", "strengthen_weaken"
            ]
          },
          "stem": { "type": "string", "minLength": 10 },
          "options": {
            "type": "object",
            "required": ["A", "B", "C", "D"],
            "additionalProperties": false,
            "properties": {
              "A": { "type": "string", "minLength": 1 },
              "B": { "type": "string", "minLength": 1 },
              "C": { "type": "string", "minLength": 1 },
              "D": { "type": "string", "minLength": 1 }
            }
          },
          "correct": { "enum": ["A", "B", "C", "D"] },
          "estimated_time_sec": { "type": "integer", "minimum": 20 },
          "explanation": {
            "type": "object",
            "required": ["correct_reasoning", "passage_anchor", "question_type_note", "distractors"],
            "additionalProperties": false,
            "properties": {
              "correct_reasoning": { "type": "string", "minLength": 20 },
              "passage_anchor":    { "type": "string", "minLength": 2 },
              "question_type_note": { "type": "string", "minLength": 10 },
              "distractors": {
                "type": "array",
                "minItems": 3,
                "maxItems": 3,
                "items": {
                  "type": "object",
                  "required": ["option", "trap_type", "why_wrong", "seductive_element"],
                  "additionalProperties": false,
                  "properties": {
                    "option": { "enum": ["A", "B", "C", "D"] },
                    "trap_type": {
                      "enum": [
                        "out_of_scope", "true_but_irrelevant",
                        "passage_language_shifted", "opposite_direction",
                        "too_broad", "too_narrow", "wrong_structural_role",
                        "half_right", "extreme_language", "near_synonym_confusion"
                      ]
                    },
                    "why_wrong":         { "type": "string", "minLength": 10 },
                    "seductive_element": { "type": "string", "minLength": 5 }
                  }
                }
              }
            }
          }
        }
      }
    },

    "vocabulary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["word", "passage_use", "meaning_here", "difficulty"],
        "additionalProperties": false,
        "properties": {
          "word":         { "type": "string", "minLength": 2 },
          "passage_use":  { "type": "string", "minLength": 5 },
          "meaning_here": { "type": "string", "minLength": 5 },
          "difficulty":   { "enum": ["easy", "medium", "hard"] }
        }
      }
    }
  }
}
